# ========================================
# lambroll deploy 時に必要な環境変数
# ========================================
# 実値はコミットしないこと (このファイルは .env.example のみコミット可)。
# 利用方法:
#   cp .env.example .env
#   # .env を編集して実値を埋める
#   set -a; . ./.env; set +a
#   lambroll deploy --function function.json --function-url function_url.json

# --- 必須 (must_env) ---

# Lambda 実行ロール ARN
# 信頼ポリシー: lambda.amazonaws.com
# 必要権限: AWSLambdaBasicExecutionRole + SSM GetParameter + DynamoDB CRUD (idproxy テーブル)
ROLE_ARN=arn:aws:iam::123456789012:role/x-mcp-lambda-role

# Lambda リージョン (LWA Layer ARN 解決にも利用)
AWS_REGION=ap-northeast-1

# idproxy の外部 URL (Function URL or 独自ドメイン、末尾スラッシュなし)
EXTERNAL_URL=https://x-mcp.example.com

# --- 認証モード (省略時 idproxy) ---

# none|apikey|idproxy
# 公開デプロイでは idproxy 推奨。
# X_MCP_AUTH=idproxy

# apikey モード時のみ必要 (BUT 公開デプロイでは idproxy を強く推奨)
# X_MCP_API_KEY=

# --- idproxy 設定 (X_MCP_AUTH=idproxy 時) ---

# OIDC Issuer (カンマ区切りで複数可)
# 例 (Google):   https://accounts.google.com
# 例 (Entra ID): https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_ISSUER=https://accounts.google.com

# 上の Issuer に対応する Client ID (カンマ区切り、Issuer と同じ順序で対応)
OIDC_CLIENT_ID=

# --- ストレージバックエンド (省略時 dynamodb) ---

# memory|sqlite|redis|dynamodb (Lambda は dynamodb 必須レベルで推奨)
# STORE_BACKEND=dynamodb

# DynamoDB テーブル名 (idproxy セッション/トークン用)
# 事前に作成が必要 (詳細は README.md 参照)
# DYNAMODB_TABLE_NAME=x-mcp-idproxy

# --- ログ ---

# debug|info|warn|error
# LOG_LEVEL=info

# ========================================
# SSM Parameter Store に投入する値 (参考)
# ========================================
# 以下は function.json から SSM 経由で参照されるため、
# `aws ssm put-parameter --type SecureString` で事前投入が必要。
# 全 6 キーの投入が deploy 前提 (X_MCP_AUTH=apikey/none 時もダミー値で投入推奨)。
#
# /x-mcp/x_api_key              (SecureString) — X API Consumer Key
# /x-mcp/x_api_secret           (SecureString) — X API Consumer Secret
# /x-mcp/x_access_token         (SecureString) — X API Access Token
# /x-mcp/x_access_token_secret  (SecureString) — X API Access Token Secret
# /x-mcp/oidc_client_secret     (SecureString) — OIDC Provider Client Secret
# /x-mcp/cookie_secret          (SecureString) — `openssl rand -hex 32` で生成
